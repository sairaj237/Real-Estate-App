# Environment Configuration for MERN Estate Application
# 
# This project uses separate environment files for frontend and backend:
# - Backend variables: backend/.env
# - Frontend variables: frontend/.env (or frontend/.env.local for local overrides)
#
# Copy this file to create your environment files:
# cp .env.example backend/.env
# cp .env.example frontend/.env.local (if needed for local frontend config)

# =============================================================================
# BACKEND ENVIRONMENT VARIABLES (backend/.env)
# =============================================================================

# Database Configuration
MONGO_URI=mongodb://localhost:27017/mern-estate

# Authentication
JWT_SECRET=your-super-secret-jwt-key-here

# AI Services
OPENAI_API_KEY=your-openai-api-key-here
OPENROUTER_API_KEY=your-openrouter-api-key-here

# Vector Database (Pinecone)
PINECONE_API_KEY=your-pinecone-api-key-here
PINECONE_ENVIRONMENT=your-pinecone-environment
PINECONE_INDEX=your-pinecone-index-name

# Server Configuration
PORT=3000

# =============================================================================
# FRONTEND ENVIRONMENT VARIABLES (frontend/.env.local)
# =============================================================================
# Note: Frontend variables must be prefixed with VITE_ to be accessible in the browser

# API Configuration
VITE_API_URL=http://localhost:3000